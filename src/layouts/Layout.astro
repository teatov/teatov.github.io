---
import "../styles/style.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

const navPages = ["/", "/about", "/blog", "/markdown"];
---

<!doctype html>
<html lang="en" class="dark scroll-smooth bg-tpurple text-twhite">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div
      class="container mx-auto mt-0 md:max-w-4xl px-4 h-full flex flex-col min-h-screen"
    >
      <header class="flex justify-center py-4">
        <ul class="flex max-w-full justify-center flex-wrap">
          {
            navPages.map((page) => (
              <li class="m-2">
                <a
                  href={page}
                  class="hover:text-tred active:text-twhite ease-in-out duration-100 p-2"
                >
                  {page}
                </a>
              </li>
            ))
          }
        </ul>
      </header>

      <slot />

      <footer class="flex justify-center p-8 mt-40 text-tgreen">
        © 2023 Anatoly Titov. Thanks
      </footer>
    </div>
  </body>
</html>
