---
import SocialLinkList from '@components/SocialLinkList.astro';
import '@fontsource/ubuntu-mono/400.css';
import '@fontsource/ubuntu-mono/700.css';
import '@fontsource/ubuntu/400.css';
import '@fontsource/ubuntu/700.css';
import { socialLinks } from '@utils/info';

interface Props {
  title: string;
}

const { title } = Astro.props;

type NavPage = {
  name: string;
  href: string;
};

const navPages: NavPage[] = [{ name: 'about', href: '#about' }];
---

<!doctype html>
<html lang="en" class="dark scroll-smooth bg-tpurple text-twhite">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div
      class="container mx-auto mt-0 flex h-full min-h-screen flex-col px-4 md:max-w-4xl"
    >
      <header class="flex justify-center py-4">
        <ul class="flex max-w-full flex-wrap justify-center">
          {
            navPages.map(page => (
              <li class="m-2">
                <a
                  href={page.href}
                  class="p-2 duration-100 ease-in-out hover:text-tred active:text-twhite"
                >
                  {page.name}
                </a>
              </li>
            ))
          }
        </ul>
      </header>

      <slot />

      <footer
        class="mt-40 flex items-center justify-between p-8 text-tgreen md:flex-row"
      >
        <aside>
          <p>&copy;{new Date().getFullYear()}. thanks.</p>
        </aside>
        <nav>
          <SocialLinkList socials={socialLinks} />
        </nav>
      </footer>
    </div>
  </body>
</html>
